# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/fencing_db?schema=public"

# Neon specific pooling url if required
# DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/fencing_db?schema=public"

# NextAuth Secret
# Generated via `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET="your_nextauth_secret_here"
AUTH_URL="http://localhost:3000"

# Webhook URL for Employee Onboarding
ONBOARDING_WEBHOOK_URL="https://your_webhook_url_here"

# CDN configuration for job completion image uploads
CDN_URL="https://your_cdn_endpoint.com"
