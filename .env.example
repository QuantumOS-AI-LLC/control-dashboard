# Database (PostgreSQL)
DATABASE_URL=""

# NextAuth Configuration
# Generate a secret via: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# n8n / GHL Integration
# This key is required for n8n to post data to the dashboard
# Should match the value in your n8n Authorization header
INTERNAL_API_KEY=""

# External Webhooks (Optional)
ONBOARDING_WEBHOOK_URL="https://n8n.your-domain.com/webhook/..."

# Asset Storage (Optional)
CDN_URL="https://your_cdn_endpoint.com"
