        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer f3nc1ng_c0ntr0l_p0rtal_s3cr3t_2024"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "job_id",
              "value": "={{ $json.body.opportunity_id }}"
            },
            {
              "name": "contact_id",
              "value": "={{ $json.body.contact_id }}"
            },
            {
              "name": "customer_name",
