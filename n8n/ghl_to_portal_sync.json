            },
            {
              "name": "city",
              "value": "={{ $json.body.contact.city }}"
            },
            {
              "name": "postal_code",
              "value": "={{ $json.body.contact.postalCode }}"
            },
            {
              "name": "pipeline_stage",
              "value": "={{ $json.body.pipeline_stage }}"
            },
            {
              "name": "fence_types",
              "value": "={{ $json.body.opportunity.custom_fields.type_of_fence || [] }}"
            },
            {
              "name": "installation_type",
              "value": "={{ $json.body.opportunity.custom_fields.installation_base }}"
            },
            {
              "name": "frost_height",
              "value": "={{ $json.body.opportunity.custom_fields.frost_height }}"
            },
            {
              "name": "frost_privacy_slats",
              "value": "={{ $json.body.opportunity.custom_fields.frost_privacy_slats === 'Yes' }}"
            },
            {
              "name": "frost_color",
              "value": "={{ $json.body.opportunity.custom_fields.frost_color }}"
            },
            {
              "name": "timeline",
              "value": "={{ $json.body.opportunity.custom_fields.target_timeline }}"
            },
            {
              "name": "access_skid_excavator",
              "value": "={{ $json.body.opportunity.custom_fields.access_limitations === 'Skid access' || $json.body.opportunity.custom_fields.access_limitations === 'Excavator access' }}"
            },
            {
              "name": "bring_back_dirt",
              "value": "={{ $json.body.opportunity.custom_fields.dirt_removal === 'Yes' }}"
            },
            {
              "name": "price_range",
              "value": "={{ $json.body.opportunity.custom_fields.price_range }}"
            },
            {
              "name": "exact_price",
              "value": "={{ $json.body.opportunity.custom_fields.exact_price }}"
            },
            {
              "name": "deposit_value",
              "value": "={{ $json.body.opportunity.custom_fields.deposit_value }}"
            },
            {
              "name": "deposit_received",
              "value": "={{ $json.body.opportunity.custom_fields.deposit_received === true || $json.body.opportunity.custom_fields.deposit_received === 'Checked' }}"
            }
          ]
        },
        "options": {}
      },
      "id": "c2b3a4d5-e6f7-8a9b-0c1d-2e3f4a5b6c7d",
